@model IEnumerable<MangaVerse.Models.Chapter>

@{
    ViewData["Title"] = "Управление на глави";
    int mangaId = ViewBag.MangaId;
    string mangaTitle = ViewBag.MangaTitle;
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="fw-bold">@mangaTitle - Глави</h2>
    </div>
    <div class="col-auto">
        <a asp-action="Create" asp-route-mangaId="@mangaId" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Добави Глава
        </a>
        <a asp-controller="Manga" asp-action="Details" asp-route-id="@mangaId" class="btn btn-outline-secondary ms-2">
            обратно към мангата
        </a>
    </div>
</div>

<div class="alert alert-warning mb-3">
    <i class="bi bi-shield-lock me-2"></i> Администраторски панел
</div>
<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Заглавие</th>
                        <th class="py-3">Дата на добавяне</th>
                        <th class="text-end pe-4 py-3">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@item.Title</td>
                            <td class="text-muted">@item.DateAdded.ToString("dd.MM.yyyy")</td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-journal-x h1 d-block mb-3"></i>
                                Няма добавени глави за тази манга.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
