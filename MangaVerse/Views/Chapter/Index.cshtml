@model IEnumerable<MangaVerse.Models.Chapter>

@{
    ViewData["Title"] = "Управление на глави";
    int mangaId = ViewBag.MangaId;
    string mangaTitle = ViewBag.MangaTitle;
}

<div class="container py-5">
    
    <div class="card shadow border-0 rounded-3 overflow-hidden">
        <div class="card-body p-4 p-md-5">
            
            <!-- Header Section -->
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-4">
                <div>
                    <h1 class="fw-bold mb-1">@mangaTitle</h1>
                    <p class="text-muted mb-0"><i class="bi bi-list-ol me-2"></i>Управление на глави</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-controller="Manga" asp-action="Details" asp-route-id="@mangaId" class="btn btn-outline-secondary px-3">
                        <i class="bi bi-arrow-left me-2"></i>Назад
                    </a>
                    <a asp-action="Create" asp-route-mangaId="@mangaId" class="btn btn-dark px-4 shadow-sm">
                        <i class="bi bi-plus-lg me-2"></i>Нова Глава
                    </a>
                </div>
            </div>

            <!-- Alert Panel -->
            <div class="alert alert-light border shadow-sm d-flex align-items-center mb-4 rounded-3" role="alert">
                <div class="bg-warning text-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                    <i class="bi bi-shield-lock-fill fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">Администраторски панел</h6>
                    <small class="text-muted">Имате пълни права да добавяте, редактирате и премахвате глави.</small>
                </div>
            </div>

            <!-- Table Section -->
            <div class="table-responsive rounded-3 border">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-secondary text-uppercase small fw-bold" style="width: 50%;">Заглавие</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold">Дата на добавяне</th>
                            <th class="text-end pe-4 py-3 text-secondary text-uppercase small fw-bold">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Title</div>
                                    <small class="text-muted">ID: @item.Id</small>
                                </td>
                                <td class="text-secondary">
                                    <i class="bi bi-calendar3 me-2 text-muted"></i>@item.DateAdded.ToString("dd.MM.yyyy")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-2 overflow-hidden">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border-end" title="Редактирай">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger" title="Изтрий">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <div class="py-4 opacity-50">
                                        <i class="bi bi-journal-album display-1 text-muted d-block mb-3"></i>
                                        <h5 class="text-muted fw-bold">Все още няма добавени глави</h5>
                                        <p class="small text-secondary">Използвайте бутона "Нова Глава", за да добавите съдържание.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Any())
            {
                <div class="mt-3 text-muted small">
                    <i class="bi bi-info-circle me-1"></i> Общо @Model.Count() глави
                </div>
            }
            
        </div>
    </div>
</div>
