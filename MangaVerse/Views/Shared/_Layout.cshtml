<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MangaVerse</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

  
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Manga" asp-action="Index">
                    MANGA<span>VERSE</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Manga" asp-action="Index">Каталог</a>
                        </li>

                        @* Показва се само на Администратора *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link btn-admin" asp-controller="Manga" asp-action="Create">
                                    <i class="bi bi-plus-lg"></i> Добавете манга
                                </a>
                            </li>
                        }
                    </ul>

                    @* Компонент за Login / Register / Logout *@
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main role="main" id="main-content">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="navbar-brand text-white p-0">MANGA<span>VERSE</span></h5>
                    <p class="small">Твоят източник за любимите манга приключения. </p>
                </div>
                <div class="col-md-2 mb-4">
                    <h5>Меню</h5>
                    <a asp-controller="Manga" asp-action="Index">Каталог</a>
                    <a href="#">Нови заглавия</a>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Помощ</h5>
                    <a href="#">Условия за ползване</a>
                    <a href="#">Поверителност</a>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Контакт</h5>
                    <p class="small mb-1"><i class="bi bi-envelope me-2"></i> info@mangaverse.com</p>
                    <p class="small"><i class="bi bi-geo-alt me-2"></i> България, 2026</p>
                </div>
            </div>

            <div class="footer-bottom d-flex justify-content-between align-items-center">
                <p class="mb-0">&copy; 2026 MANGA VERSE. Всички права запазени.</p>
                <div class="h4 m-0">
                    <i class="bi bi-facebook me-3"></i>
                    <i class="bi bi-instagram me-3"></i>
                    <i class="bi bi-twitter-x"></i>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>