@model MangaVerse.Models.Manga

@{
    ViewData["Title"] = "Добави Манга";
}

<div class="container mt-4 content-panel" style="max-width: 600px;">
    <h2 class="mb-4">Добавяне на ново заглавие</h2>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Заглавие</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Author" class="form-label">Автор</label>
            <input asp-for="Author" class="form-control" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="ReleaseYear" class="form-label">Година</label>
                <input asp-for="ReleaseYear" class="form-control" />
                <span asp-validation-for="ReleaseYear" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Genre" class="form-label">Жанр</label>
                <select asp-for="Genre" class="form-select" asp-items="Html.GetEnumSelectList<MangaVerse.Models.MangaGenre>()">
                    <option value="">Избери жанр</option>
                </select>
                <span asp-validation-for="Genre" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Качи корица (JPG/PNG)</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Описание</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="ChaptersCount" class="form-label">Брой глави</label>
                <input asp-for="ChaptersCount" class="form-control" />
                <span asp-validation-for="ChaptersCount" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Status" class="form-label">Статус</label>
                <select asp-for="Status" class="form-select">
                    <option value="Продължаващо">Продължаващо</option>
                    <option value="Завършено">Завършено</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success px-4">Запази</button>
            <a asp-action="Index" class="btn btn-secondary px-4">Назад</a>
        </div>
    </form>
</div>