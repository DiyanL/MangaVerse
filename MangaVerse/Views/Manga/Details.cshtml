@model MangaVerse.Models.Manga

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="bg-white rounded shadow p-4 p-md-5 position-relative overflow-hidden">
        <div class="row">
            <div class="col-md-4 mb-4 mb-md-0">
                <img src="@Model.CoverImageUrl" class="img-fluid shadow rounded w-100" alt="@Model.Title" style="object-fit: cover;">
            </div>

            <div class="col-md-8">
                <h1 class="display-4 fw-bold mb-3">@Model.Title</h1>
                <h4 class="text-muted mb-4 border-bottom pb-3">Автор: @Model.Author</h4>

                <div class="mb-4">
                    <span class="badge bg-danger fs-6 me-1">@Model.Genre</span> 
                    <span class="badge bg-secondary fs-6 me-1">@Model.Status</span>
                    <span class="badge bg-dark fs-6">Година: @Model.ReleaseYear</span>
                </div>

                <h5 class="fw-bold mt-4">Описание</h5>
                <p class="lead text-secondary" style="font-size: 1.1rem;">@Model.Description</p>

                <div class="row mt-4 mb-4">
                    <div class="col-auto">
                        <div class="p-3 bg-light rounded text-center border">
                            <div class="fw-bold h5 mb-0">@Model.ChaptersCount</div>
                            <div class="small text-muted">Глави</div>
                        </div>
                    </div>
                     @if (User.IsInRole("Admin"))
                      {
                            <div class="col-auto">
                                <div class="p-3 bg-light rounded text-center border">
                                    <div class="fw-bold h5 mb-0">#@Model.Id</div>
                                    <div class="small text-muted">ID</div>
                                </div>
                            </div>
                        }
                </div>
                
             

                <!-- Меню за четене (За Потребители) -->
                @if(Model.Chapters != null && Model.Chapters.Any())
                {
                    <div class="mb-5 p-4 bg-light rounded border">
                        <h5 class="fw-bold mb-3"><i class="bi bi-book me-2"></i>Започни да четеш</h5>
                        <select class="form-select form-select-lg mb-3 shadow-sm" onchange="if(this.value) window.location.href=this.value;">
                            <option value="">Избери глава...</option>
                            @foreach(var chapter in Model.Chapters.OrderBy(c => c.Title))
                            {
                                <option value="/Chapter/Read/@chapter.Id">@chapter.Title</option>
                            }
                        </select>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-5">
                       <i class="bi bi-info-circle me-2"></i> Все още няма качени глави за тази манга.
                    </div>
                }

            

                <div class="mt-5 d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-dark px-4"><i class="bi bi-arrow-left me-2"></i>Каталог</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Редактирай</a>
                        <a asp-controller="Chapter" asp-action="Index" asp-route-mangaId="@Model.Id" class="btn btn-dark px-4">
                            <i class="bi bi-list-ol me-2"></i> Глави
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-4">Изтрий</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>