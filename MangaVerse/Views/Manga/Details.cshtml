@model MangaVerse.Models.Manga

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <img src="@Model.CoverImageUrl" class="img-fluid shadow rounded" alt="@Model.Title">
        </div>

        <div class="col-md-8">
            <h1 class="display-4 fw-bold">@Model.Title</h1>
            <h4 class="text-muted mb-4">Автор: @Model.Author</h4>

            <div class="mb-4">
                <span class="badge bg-primary fs-6">@Model.Genre</span>
                <span class="badge bg-info fs-6">@Model.Status</span>
                <span class="badge bg-dark fs-6">Година: @Model.ReleaseYear</span>
            </div>

            <h5>Описание:</h5>
            <p class="lead">@Model.Description</p>

            <ul class="list-group list-group-flush mt-4" style="max-width: 300px;">
                <li class="list-group-item"><strong>Брой глави:</strong> @Model.ChaptersCount</li>
                <li class="list-group-item"><strong>ID на заглавието:</strong> #@Model.Id</li>
            </ul>

            <div class="mt-5">
                <a asp-action="Index" class="btn btn-outline-secondary">Върни се в каталога</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning ms-2">Редактирай</a>
                }
            </div>
        </div>
    </div>
</div>